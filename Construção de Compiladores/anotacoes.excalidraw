    {
      "id": "afSTEnSyMAX96qXyWCrWA",
      "type": "text",
      "x": 407,
      "y": 345,
      "width": 448.79998779296875,
      "height": 300,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a6",
      "roundness": null,
      "seed": 283617158,
      "version": 587,
      "versionNonce": 161464429,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773085586321,
      "link": null,
      "locked": false,
      "text": "1953 - Interpretador Speedcoding para IBM 701\n       10 a 20x mais lento que código escrito a mão\n       Consumia 300 bytes (30% da memoria da 704)\n       \n1954 - IBM 704\n       Altos custos de software\n       Como escrever código mais eficientemente?\n\n1957 - FORTRAN (FORmulas TRANslated)\n       Fórmulas traduzidas para código de máquina\n       Produziu um corpo teórico gigante\n       Uniu teoria e prática\n       \n1958 - 50% dos programas eram escritos em FORTRAN\n       Melhorou a produtividade",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1953 - Interpretador Speedcoding para IBM 701\n       10 a 20x mais lento que código escrito a mão\n       Consumia 300 bytes (30% da memoria da 704)\n       \n1954 - IBM 704\n       Altos custos de software\n       Como escrever código mais eficientemente?\n\n1957 - FORTRAN (FORmulas TRANslated)\n       Fórmulas traduzidas para código de máquina\n       Produziu um corpo teórico gigante\n       Uniu teoria e prática\n       \n1958 - 50% dos programas eram escritos em FORTRAN\n       Melhorou a produtividade",
      "autoResize": true,
      "lineHeight": 1.25
    },
