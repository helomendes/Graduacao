      "link": null,
      "locked": false,
      "text": "Um compilador opera em fases\nCada fase transforma o código fonte de uma representação\npara outra",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
