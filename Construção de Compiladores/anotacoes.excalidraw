    {
      "id": "OyeK3d6t0T_htSH7T_S1P",
      "type": "text",
      "x": 407,
      "y": 682,
      "width": 492.79998779296875,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
